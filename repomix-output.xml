/* ==========================================================================
   Centarius Leaderboard Design System (Vanilla CSS)
   ========================================================================== */

/* Variables & Theme Tokens */
:root {
    --bg-dark: #070913;
    --bg-surface: rgba(18, 22, 41, 0.45);
    --border-color: rgba(255, 255, 255, 0.08);
    --accent-cyan: #00f0ff;
    --accent-purple: #bd00ff;
    --accent-gold: #ffd700;
    --accent-silver: #e2e8f0;
    --accent-bronze: #ff9f43;
    --text-primary: #ffffff;
    --text-secondary: #8f9cae;
    --font-main: 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    --glow-cyan: 0 0 15px rgba(0, 240, 255, 0.35);
    --glow-purple: 0 0 15px rgba(189, 0, 255, 0.35);
    --transition-smooth: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

/* Reset & Base Styles */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    background-color: var(--bg-dark);
    font-family: var(--font-main);
    color: var(--text-primary);
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
}

/* Glassmorphism Background Glows */
.glass-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    background: radial-gradient(circle at 10% 20%, rgba(189, 0, 255, 0.08) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(0, 240, 255, 0.08) 0%, transparent 40%);
    pointer-events: none;
}

/* Container & Layout */
.container {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
}

/* Header */
header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-color);
}

.logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.pulse-dot {
    width: 10px;
    height: 10px;
    background-color: var(--accent-purple);
    border-radius: 50%;
    box-shadow: var(--glow-purple);
    animation: pulse 2s infinite;
}

.logo h1 {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: 2px;
    background: linear-gradient(135deg, #fff 0%, #a5b4fc 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.logo .subtitle {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: var(--accent-cyan);
    font-weight: 600;
    border-left: 1px solid var(--border-color);
    padding-left: 0.75rem;
    margin-left: 0.5rem;
}

.status-indicator {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-color);
    padding: 0.5rem 1rem;
    border-radius: 50px;
}

.live-dot {
    width: 8px;
    height: 8px;
    background-color: var(--accent-cyan);
    border-radius: 50%;
    box-shadow: var(--glow-cyan);
    animation: pulse 1.5s infinite;
}

.live-text {
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
}

/* Dashboard Grid Layout */
.dashboard-grid {
    display: grid;
    grid-template-columns: 350px 1fr;
    gap: 2rem;
    align-items: start;
}

@media (max-width: 900px) {
    .dashboard-grid {
        grid-template-columns: 1fr;
    }
}

/* Panels (Glassmorphism Cards) */
.panel {
    background: var(--bg-surface);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 1.75rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
    transition: var(--transition-smooth);
}

.panel:hover {
    border-color: rgba(255, 255, 255, 0.15);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.35);
}

.panel h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    letter-spacing: 0.5px;
    background: linear-gradient(to right, #fff, #a5b4fc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

/* Divider line */
.divider {
    border: 0;
    height: 1px;
    background: linear-gradient(to right, var(--border-color), transparent);
    margin: 1.75rem 0;
}

/* Form Styles */
.form-group {
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.form-group label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-secondary);
}

/* Custom Styled Select */
.select-wrapper {
    position: relative;
    width: 100%;
}

.select-wrapper::after {
    content: "▼";
    font-size: 0.7rem;
    color: var(--text-secondary);
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
}

.custom-select {
    appearance: none;
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    color: var(--text-primary);
    font-family: var(--font-main);
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: var(--transition-smooth);
}

.custom-select:focus {
    outline: none;
    border-color: var(--accent-cyan);
    box-shadow: var(--glow-cyan);
}

.custom-select option {
    background-color: #0b0d19;
    color: var(--text-primary);
}

/* Inputs */
input[type="text"],
input[type="number"] {
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    color: var(--text-primary);
    font-family: var(--font-main);
    font-size: 0.95rem;
    transition: var(--transition-smooth);
}

input[type="text"]:focus,
input[type="number"]:focus {
    outline: none;
    border-color: var(--accent-purple);
    box-shadow: var(--glow-purple);
}

/* Interactive Glowing Button */
.glow-button {
    width: 100%;
    background: linear-gradient(135deg, var(--accent-purple) 0%, #9000ff 100%);
    border: none;
    border-radius: 8px;
    padding: 0.9rem;
    color: white;
    font-family: var(--font-main);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 1px;
    cursor: pointer;
    box-shadow: var(--glow-purple);
    transition: var(--transition-smooth);
}

.glow-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 25px rgba(189, 0, 255, 0.6);
}

.glow-button:active {
    transform: translateY(0);
}

/* Metadata Card */
.game-meta-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.25rem;
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.stat-label {
    font-size: 0.85rem;
    color: var(--text-secondary);
}

.stat-value {
    font-weight: 600;
    font-size: 0.95rem;
}

#stat-top-score {
    color: var(--accent-cyan);
    font-weight: 800;
}

.active-badge {
    color: var(--accent-cyan);
    background: rgba(0, 240, 255, 0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: bold;
    letter-spacing: 0.5px;
    text-transform: uppercase;
}

.panel-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
    line-height: 1.4;
}

/* Right Panel: Leaderboard Table Layout */
.panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
}

.limit-badge {
